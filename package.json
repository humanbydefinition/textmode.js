{
	"name": "textmode.js",
	"version": "0.13.0",
	"description": "textmode.js is a lightweight creative coding library for creating real-time ASCII art on the web.",
	"type": "module",
	"engines": {
		"node": ">=20.8.1"
	},
	"main": "./dist/textmode.umd.js",
	"module": "./dist/textmode.esm.js",
	"types": "./dist/types/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/textmode.esm.js",
			"require": "./dist/textmode.umd.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "vite --port 5177 --host",
		"build:bundle": "vite build",
		"build:types": "tsc -p tsconfig.build.json",
		"build": "npm run build:bundle && npm run build:types",
		"check": "npm run check:format && npm run lint && npm run lint:md && npm run check:types && npm run check:api-docs && npm run test && npm run build",
		"check:api-docs": "node ./scripts/check-public-api-docs.mjs",
		"dev:docs": "typedoc --watch",
		"build:docs": "typedoc",
		"preview": "vite preview",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest --coverage",
		"format": "prettier --write .",
		"check:format": "prettier --check .",
		"check:types": "tsc --noEmit",
		"lint:md": "markdownlint-cli2",
		"lint:md:fix": "markdownlint-cli2 --fix",
		"lint": "eslint src --config eslint.config.js",
		"lint:jsdoc": "npm run lint",
		"contributors:add": "all-contributors add",
		"contributors:generate": "all-contributors generate",
		"prepare": "husky"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@eslint/js": "^9.39.4",
		"@mapwhit/glsl-minify": "^1.0.0",
		"@rollup/plugin-terser": "^0.4.4",
		"@semantic-release/exec": "^7.1.0",
		"@types/node": "^24.0.13",
		"@vitest/ui": "^3.1.2",
		"all-contributors-cli": "^6.26.1",
		"eslint": "^9.39.2",
		"eslint-plugin-jsdoc": "^62.9.0",
		"globals": "^17.5.0",
		"husky": "^9.1.7",
		"jsdom": "^27.4.0",
		"lint-staged": "^16.4.0",
		"markdownlint-cli2": "^0.22.1",
		"markdownlint-cli2-formatter-default": "^0.0.6",
		"poline": "^0.13.1",
		"prettier": "^3.8.3",
		"semantic-release": "^25.0.3",
		"typedoc": "^0.28.19",
		"typedoc-plugin-frontmatter": "^1.3.1",
		"typedoc-plugin-markdown": "^4.11.0",
		"typedoc-vitepress-theme": "^1.1.2",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.59.0",
		"vite": "^6.3.4",
		"vitest": "^3.1.2"
	},
	"keywords": [
		"ascii",
		"petscii",
		"textmode",
		"canvas",
		"webgl",
		"creative-coding",
		"art",
		"design",
		"graphics",
		"ascii-art"
	],
	"author": "humanbydefinition <hello@textmode.art> (https://code.textmode.art)",
	"license": "MIT",
	"homepage": "https://code.textmode.art",
	"lint-staged": {
		"*": "prettier --ignore-unknown --write"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/humanbydefinition/textmode.js-dev.git"
	},
	"bugs": {
		"url": "https://github.com/humanbydefinition/textmode.js/issues"
	}
}
